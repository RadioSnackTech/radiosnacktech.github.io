<style>
  main { max-width: 100%; }
  iframe {
    border: 0;
    width: 100%;
    height: 600px;
  }
  .cal-desktop { display: block; }
  .cal-mobile { display: none; }
  @media (max-width: 768px) {
    .cal-desktop { display: none; }
    .cal-mobile  { display: block; }
  }
</style>

<h1>{{ translations[page.lang].nav.calendar.label }}</h1>

<iframe
