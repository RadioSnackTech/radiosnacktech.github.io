  src="https://calendar.google.com/calendar/embed?src=fbe3c8aa05cb3a88d705f29590ffb2b97400bb26be805ecb902e75ee82893489%40group.calendar.google.com&ctz=America%2FToronto&hl={{ page.lang }}"
></iframe>

<iframe
  class="cal-mobile"
  src="https://calendar.google.com/calendar/embed?src=fbe3c8aa05cb3a88d705f29590ffb2b97400bb26be805ecb902e75ee82893489%40group.calendar.google.com&ctz=America%2FToronto&hl={{ page.lang }}&mode=AGENDA"
></iframe>
