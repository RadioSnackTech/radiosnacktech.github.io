---
layout: base.njk
title: Calendar - Radio Snack
permalink: /calendar/
bodyClass: calendar-page
---

<h1>Calendar</h1>

{% for month in gcalevents.months %}
<h2>{{ month.name }}</h2>

<table class="cal-table">
  <thead>
    <tr>
      <th>Sun</th><th>Mon</th><th>Tue</th><th>Wed</th><th>Thu</th><th>Fri</th><th>Sat</th>
    </tr>
  </thead>
  <tbody>
    {% for week in month.weeks %}
    <tr>
      {% for cell in week %}
        {% if cell %}
          <td class="{% if cell.dateStr == gcalevents.today %}today{% endif %}">
            <time datetime="{{ cell.dateStr }}">{{ cell.day }}</time>
            <ul>
              {% for event in cell.events %}
                {%- set eventUrl = event.start | findLocalEventUrl(events) %}
                {%- set eventTime = event.start | formatEventTime %}
                <li>
                  <a {% if eventUrl %}href="{{ eventUrl }}" target="_blank" rel="noopener"{% endif %} class="cal-event">
                    <time>{{ eventTime }}</time> {{ event.title }}
                  </a>
                </li>
              {% endfor %}
            </ul>
          </td>
        {% else %}
          <td class="cal-day"></td>
        {% endif %}
      {% endfor %}
    </tr>
    {% endfor %}
  </tbody>
</table>

<dl class="cal-list">
  {% for week in month.weeks %}
    {% for cell in week %}
      {% if cell and cell.events.length > 0 and cell.dateStr >= gcalevents.today %}
        <dt>{{ cell.dateStr | formatCalDate }}</dt>
        {% for event in cell.events %}
          {%- set eventUrl = event.start | findLocalEventUrl(events) %}
          {%- set eventTime = event.start | formatEventTime %}
          <dd>
            <a {% if eventUrl %}href="{{ eventUrl }}" target="_blank" rel="noopener"{% endif %} class="cal-list-item">
              <div>
                <time><strong>{{ eventTime }}</strong></time>
                <p>{{ event.title }}</p>
              </div>
              {%- if eventUrl %}<span class="cal-list-register">Register</span>{% endif %}
            </a>
          </dd>
        {% endfor %}
      {% endif %}
    {% endfor %}
  {% endfor %}
</dl>

{% endfor %}
